<% if (title) { %>
<h1><%= title %></h1>
<% } else {
  res.redirect('/')
} %>

<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
 <% errors.array().forEach(error => { %>
   <li><%= error.msg %></li>
<%  }) %>
 </ul>
<% } %>

<div class="account-container">
        <form id="passwordForm" action="/account/change" method="POST">
            <div class="input-group password-field">
                <label for="account_password">Password:</label>
                <span>Passwords must be at least 12 characters and contain at least 1 number, 1 capital letter and 1 special character</span> 
                <input class="me" type="password" id="account_password" name="account_password" required pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{6,}$">
                <span id="toggler"><img src="/images/site/closed-eye.png" alt="Eye"></span>
                <span id="cpwd">Please Note that your current password will be changed when you click on the change password button </span>
            </div>
            <button type="submit">Change Password</button>   
            <input type="hidden" name="account_id"
            <% if(locals.account_id) { %> value="<%= locals.account_id %>"
            <% } %>>   
        </form>
</div>