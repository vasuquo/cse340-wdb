<% if (title) { %>
<h1><%= title %></h1>
<% } else {
  res.redirect('/')
} %>

<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
 <% errors.array().forEach(error => { %>
   <li><%= error.msg %></li>
<%  }) %>
 </ul>
<% } %>

<h2>Welcome <%= fname %></h2>

<a href="/account/menu">Update account information</a>

<% if (type === "Admin" || type === "Employee") { %>
  <h3>Inventory Management</h3>

  <p><a href="/inv">Click to access Inventory Management</a></p>

<%  } %>
